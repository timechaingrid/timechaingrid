{
  "name": "timechaingrid",
  "version": "0.1.0",
  "private": true,
  "description": "Timechain Grid — Bitcoin's digital real estate, block by block. Every coin a tile, every block opens new tiles. timechaingrid.com.",
  "homepage": "https://timechaingrid.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/timechaingrid/timechaingrid.git"
  },
  "bugs": {
    "url": "https://github.com/timechaingrid/timechaingrid/issues"
  },
  "author": "Timechain Grid team",
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "privacy-audit": "bash scripts/privacy-audit.sh out",
    "substrate:dump": "vitest run scripts/dump-substrate.test.ts",
    "vault:generate": "node chain-tools/vault/generate-grid.mjs",
    "vault:validate": "node chain-tools/vault/validate.mjs vault-grid",
    "deploy": "next build && rm -rf out/blocks && wrangler pages deploy out --project-name=timechaingrid --branch=main"
  },
  "dependencies": {
    "next": "^16.2.4",
    "pixi.js": "^8.18.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9",
    "eslint-config-next": "^16.2.4",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.4",
    "wrangler": "^4"
  }
}
